{
  "name": "echo-gestion-desktop",
  "version": "1.0.0",
  "description": "Application Desktop native pour Echo Gestion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --win",
    "package:setup": "electron-builder --win nsis",
    "package:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.echosdechezmoi.gestiodesktop",
    "productName": "Echo Gestion",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "image_circulaire_recadree.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Echo Gestion"
    },
    "files": [
      "**/*",
      "!node_modules/**/*"
    ]
  }
}
